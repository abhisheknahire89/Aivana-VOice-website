# Required for REST voice; also set for server (Gemini Live).
VITE_GEMINI_API_KEY=your_gemini_api_key

# Gemini Live: set one of these so the app uses Live instead of REST. Local: npm run dev:server then ws://localhost:3001/voice
# Production (Railway): wss://<your-railway-host>/voice e.g. wss://voicebot-production-3506.up.railway.app/voice
# VITE_VOICE_WS_URL=wss://voicebot-production-3506.up.railway.app/voice
# VITE_VOICEBOT_WS_URL=wss://your-voicebot.com/browser-voice

# Optional: set VITE_VOICE_DEBUG=true to log [Voice] [client] in browser console for debugging.
# Optional (server): set VOICE_DEBUG=1 when running the voice server to log [Voice] [server] to the terminal.
