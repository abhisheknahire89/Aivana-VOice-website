css
.tap-to-talk-btn {
display: flex;
flex-direction: column;
align-items: center;
gap: 6px;
margin-top: 16px;
background: none;
border: none;
cursor: pointer;
}
.mic-emoji {
font-size: 1.6rem;
filter: grayscale(1) brightness(0.7); /* makes it grey */
transition: filter 0.3s;
}
.tap-to-talk-btn:hover .mic-emoji {
filter: grayscale(0) brightness(1); /* colorful on hover */
}
.tap-label {
font-size: 0.75rem;
color: rgba(255, 255, 255, 0.4);
text-transform: uppercase;
letter-spacing: 0.1em;
}
.tap-to-talk-btn:hover .tap-label {
color: rgba(255, 255, 255, 0.8);
}
